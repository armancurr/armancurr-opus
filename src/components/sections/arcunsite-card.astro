---
import { PhCirclesThree } from "phosphor-icons-astro";
---

<a
  href="https://arcun.site"
  target="_blank"
  rel="noopener noreferrer"
  aria-label="Open arcun.site"
  class="group block h-full w-full"
>
  <div
    class="relative flex h-full min-h-[240px] transform cursor-default cursor-pointer items-center justify-center overflow-hidden rounded-sm border border-neutral-900 bg-black transition-all duration-200 active:scale-95 sm:min-h-[280px] md:min-h-[320px]"
  >
    <div
      class="pointer-events-none absolute inset-0 z-0 rounded-sm opacity-0 transition-opacity duration-300 group-hover:opacity-100"
      style="background-image: radial-gradient(circle at 50% 100%, rgba(70, 85, 110, 0.5) 0%, transparent 60%), radial-gradient(circle at 50% 100%, rgba(99, 102, 241, 0.4) 0%, transparent 70%), radial-gradient(circle at 50% 100%, rgba(181, 184, 208, 0.3) 0%, transparent 80%);"
    >
    </div>
    <span
      class="absolute top-0 left-0 z-10 h-6 w-6 origin-top-left scale-0 transform rounded-tl-sm border-2 border-neutral-300 border-r-transparent border-b-transparent transition-transform duration-200 group-hover:scale-100"
    ></span>
    <span
      class="absolute top-0 right-0 z-10 h-6 w-6 origin-top-right scale-0 transform rounded-tr-sm border-2 border-neutral-300 border-b-transparent border-l-transparent transition-transform duration-200 group-hover:scale-100"
    ></span>
    <span
      class="absolute bottom-0 left-0 z-10 h-6 w-6 origin-bottom-left scale-0 transform rounded-bl-sm border-2 border-neutral-300 border-t-transparent border-r-transparent transition-transform duration-200 group-hover:scale-100"
    ></span>
    <span
      class="absolute right-0 bottom-0 z-10 h-6 w-6 origin-bottom-right scale-0 transform rounded-br-sm border-2 border-neutral-300 border-t-transparent border-l-transparent transition-transform duration-200 group-hover:scale-100"
    ></span>
    <PhCirclesThree
      size={48}
      weight="fill"
      class="relative z-10 text-neutral-400 transition-colors duration-200 group-hover:text-neutral-300"
    />
  </div>
</a>
