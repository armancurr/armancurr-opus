---
import { PhDownloadSimple } from "phosphor-icons-astro";
---

<div class="flex h-full items-center justify-center p-8">
  <div class="space-y-4 text-center">
    <div class="mx-auto w-fit rounded-full bg-neutral-800 p-4">
      <PhDownloadSimple size={32} weight="fill" class="text-neutral-400" />
    </div>
    <div class="space-y-2">
      <p class="text-lg font-medium text-neutral-200">
        PDF Preview Not Available
      </p>
      <p class="max-w-md text-sm text-neutral-400">
        Your browser doesn't support PDF preview. Please download the file to
        view it.
      </p>
      <button
        type="button"
        onclick="window.open('/armankar.pdf', '_blank')"
        class="mt-4 inline-flex items-center gap-2 rounded-lg border border-neutral-800 px-6 py-3 text-sm font-medium text-neutral-200 transition-colors hover:border-neutral-700 hover:bg-neutral-800/50"
      >
        <PhDownloadSimple size={16} weight="fill" />
        Download Resume
      </button>
    </div>
  </div>
</div>
